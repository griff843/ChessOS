# Chess-OS Environment Variables
# Copy to .env and adjust values as needed

# Engine mode for the training pipeline
# "stub" = deterministic fake evals (fast, no Stockfish needed)
# "stockfish" = real Stockfish evaluation (requires binary at data/stockfish/stockfish.exe)
ENGINE_MODE=stub

# Directory containing PGN game files (absolute path required)
# PGN_DIR=C:/dev/chess-os/data/pgn

# Web UI port (default: 3000)
# PORT=3001
